# === DATABASE ===
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/vastrahub?retryWrites=true&w=majority

# === AUTH ===
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-long-here
BETTER_AUTH_URL=http://localhost:3001
# Better-Auth trusted origins (supports comma-separated list for multiple frontends)
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# === CLOUDFLARE R2 ===
R2_ACCOUNT_ENDPOINT=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=vastrahub-media
R2_REGION=
R2_PUBLIC_URL=https://media.vastrahub.com

# === APP ===
PORT=3001
NODE_ENV=development
# Allowed CORS origins (supports comma-separated list for multiple frontends)
FRONTEND_URL=http://localhost:3000

# === RAZORPAY (Payment Gateway) ===
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxx

# === ICICI (Payment Gateway) ===
# Merchant account ID issued by ICICI Bank
ICICI_MERCHANT_ID=
# Aggregator ID issued by ICICI Bank (sent alongside merchantId on every call)
ICICI_AGGREGATOR_ID=
# Secret key used to compute/verify the secureHash (HMAC-SHA256)
ICICI_SHARED_SECRET=
# Optional separate secret for inbound webhooks (falls back to ICICI_SHARED_SECRET)
ICICI_WEBHOOK_SECRET=
# Base URL — UAT: https://pgpayuat.icicibank.com | PROD: https://pgpay.icicibank.com
ICICI_BASE_URL=https://pgpayuat.icicibank.com
# Public callback URL ICICI POSTs the result to (must be reachable by ICICI servers).
# Leave blank to default to ${BETTER_AUTH_URL}/api/v1/payment/icici/callback
ICICI_RETURN_URL=
