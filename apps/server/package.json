{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --build",
    "start": "node dist/server.js",
    "lint": "echo 'No linter configured yet'",
    "type-check": "tsc --noEmit",
    "seed": "tsx --env-file=.env src/db/seed/seed.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/s3-request-presigner": "^3",
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/env": "^6.0.0",
    "@fastify/formbody": "^8",
    "@fastify/helmet": "^13",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.49",
    "better-auth": "^1",
    "fastify": "^5",
    "fastify-plugin": "^5",
    "mongoose": "^8",
    "nanoid": "^5",
    "razorpay": "^2.9.6",
    "sanitize-html": "^2",
    "slugify": "^1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/sanitize-html": "^2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4",
    "typescript": "^5"
  }
}
